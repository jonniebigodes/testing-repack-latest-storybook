{
  "name": "repack",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "storybook:ios": "cross-env STORYBOOK_ENABLED=true react-native run-ios",
    "storybook:android": "cross-env STORYBOOK_ENABLED=true react-native run-android",
    "webpackstart:nocache": "cross-env STORYBOOK_ENABLED=true npx react-native webpack-start --reset-cache",
    "android:clean": "npm run storybook:android -- --no-packager",
    "android:release": "npx react-native webpack-bundle --entry-file index.js --platform android --dev false --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "android:build-release": "npx @expo/repack-app --platform android --source-app storybook.apk",
    "chromatic:build-react-native": "chromatic --project-token=chpt_5f5b800133eab85 -d custom-build-dir",
    "chromatic:rn-help": "chromatic react-native-build --help",
    "chromatic:dualbuild": "chromatic react-native-build",
    "chromatic:generate-manifest": "chromatic generate-manifest -o custom-build-dir",
    "chromatic:ios-release": "chromatic react-native-build --platform ios",
    "chromatic:android-release": "chromatic react-native-build --platform android",
    "chromatic:ios-release-configuration": "chromatic react-native-build --platform ios -d custom-build-dir",
    "chromatic:android-release-configuration": "chromatic react-native-build --platform android -d custom-build-dir"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-native-community/slider": "^5.2.0",
    "@react-native/new-app-screen": "0.84.1",
    "@storybook/addon-ondevice-actions": "^10.4.4",
    "@storybook/addon-ondevice-controls": "^10.4.4",
    "@storybook/react-native": "^10.4.4",
    "@storybook/react-native-ui-lite": "^10.4.4",
    "babel-loader": "^8.4.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.84.1",
    "react-native-gesture-handler": "^2.31.2",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-svg": "^15.15.5",
    "react-native-worklets": "^0.8.3",
    "storybook": "^10.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@callstack/repack": "^5.2.5",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@rspack/core": "^1.7.8",
    "@swc/helpers": "^0.5.19",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "chromatic": "^16.10.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
